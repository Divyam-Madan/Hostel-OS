NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hostel-os
JWT_SECRET=use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Optional: if omitted, OTP codes are printed to the server console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=HostelOS <noreply@yourcollege.edu>

HEALTH_CENTER_EMAIL=health@yourcollege.edu

# Optional: Gemini summaries (admin only)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Frontend URL (CORS + Socket.IO)
CLIENT_ORIGIN=http://localhost:5173

# Start API even if Mongo is unreachable (503 on data routes). Use for local UI dev only.
# ALLOW_NO_DB=true

# Override default hardcoded admin if needed
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
